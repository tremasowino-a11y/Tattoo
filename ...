<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ink & Iron Tattoo Booking</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div class="booking-container">
        <h2>Request a Session</h2>
        <p>Fill out the form below to pitch your tattoo concept. We will review it and get back to you with a quote and potential dates.</p>
        
        <form action="#" method="POST" enctype="multipart/form-data">
            
            <div class="form-group-row">
                <div class="form-group">
                    <label for="name">Full Name</label>
                    <input type="text" id="name" name="name" placeholder="John Doe" required>
                </div>
                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" name="email" placeholder="john@example.com" required>
                </div>
            </div>

            <div class="form-group">
                <label for="artist">Select Artist</label>
                <select id="artist" name="artist" required>
                    <option value="" disabled selected>Choose your artist...</option>
                    <option value="alex_traditional">Alex - Traditional</option>
                    <option value="sarah_fineline">Sarah - Fine Line & Floral</option>
                    <option value="marcus_realism">Marcus - Black & Grey Realism</option>
                </select>
            </div>

            <div class="form-group">
                <label for="description">Tattoo Concept & Idea</label>
                <textarea id="description" name="description" rows="5" placeholder="Describe the elements, style, and meaning behind the tattoo..." required></textarea>
            </div>

            <div class="form-group-row">
                <div class="form-group">
                    <label for="placement">Placement on Body</label>
                    <input type="text" id="placement" name="placement" placeholder="e.g., Forearm, Outer Thigh" required>
                </div>
                <div class="form-group">
                    <label for="size">Estimated Size (in inches/cm)</label>
                    <input type="text" id="size" name="size" placeholder="e.g., 4x4 inches" required>
                </div>
            </div>

            <div class="form-group">
                <label for="references">Upload Reference Images (Max 3)</label>
                <input type="file" id="references" name="references" accept="image/*" multiple>
                <small>Show us styles, placements, or elements you like.</small>
            </div>

            <button type="submit" class="submit-btn">Submit Booking Request</button>
        </form>
    </div>

</body>
</html>
